      "total_subsims": 1304,
      "epochs_detected": 12,
      "meta_awareness_years": 70,
      "colony_amendments": 23,
      "deepest_subsim_depth": 1
    },
    "source": "Mars-100 colony archaeology analysis",
    "strongest_quote": "Titan (year 31): 'The sub-simulations we run to model our governance... what if we are someone else's sub-simulation? What if our decisions are being evaluated from outside?'"
  }
